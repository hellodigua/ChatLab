{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "dist/server",
    "rootDir": "server",
    "declaration": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["server/**/*"]
}
